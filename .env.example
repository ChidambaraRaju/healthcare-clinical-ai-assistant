# ========================================
# Healthcare Clinical AI Assistant
# Environment Configuration Template
# ========================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ========================================
# Application Settings
# ========================================
APP_NAME=Healthcare Clinical AI Assistant
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ========================================
# Backend API Settings
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://user:password@localhost:5432/clinical_ai
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ========================================
# Redis Configuration (for cache & Celery)
# ========================================
REDIS_URL=redis://localhost:6379/0

# ========================================
# Security & Authentication
# ========================================
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-change-this

# Session
SESSION_TIMEOUT_MINUTES=30
MAX_SESSIONS_PER_USER=5

# MFA
MFA_ENABLED=false
MFA_ISSUER=HealthcareAI

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# ========================================
# ML Service Configuration
# ========================================
ML_SERVICE_URL=http://localhost:8001
MODEL_CACHE_DIR=/app/models

# Model Settings
DEVICE=cpu  # cpu, cuda, or mps

# ========================================
# OpenAI Configuration (for LLM features)
# ========================================
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000

# ========================================
# Frontend Settings
# ========================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ========================================
# AWS Configuration (for deployment)
# ========================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# S3
S3_BUCKET_NAME=clinical-ai-documents

# CloudFront
CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id

# ECS (Fargate)
ECS_CLUSTER_NAME=clinical-ai-cluster
ECS_SERVICE_BACKEND=backend
ECS_SERVICE_ML=ml

# ========================================
# Monitoring & Logging
# ========================================
PROMETHEUS_ENABLED=false
SENTRY_DSN=your-sentry-dsn

# Audit Logging (HIPAA requirement)
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=2190  # 6 years for HIPAA

# ========================================
# HIPAA Compliance
# ========================================
HIPAA_MODE=true
DATA_RETENTION_DAYS=2555  # 7 years minimum

# ========================================
# Feature Flags
# ========================================
ENABLE_CODE_SUGGESTIONS=true
ENABLE_DOCUMENT_SUMMARY=true
ENABLE_VOICE_TRANSCRIPTION=false
ENABLE_LLM_GENERATION=true

# ========================================
# Email Configuration (optional)
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@clinicalai.com

# ========================================
# Third-Party Services (optional)
# ========================================
# Slack for notifications
SLACK_WEBHOOK_URL=your-slack-webhook-url

# Security scanning
SNYK_TOKEN=your-snyk-token

# ========================================
# Development Only
# ========================================
# Enable test endpoints
ENABLE_TEST_ENDPOINTS=false

# Mock AI responses for testing
MOCK_AI_RESPONSES=false
